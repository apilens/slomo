            "group": "Python API",
            "pages": [
              "reference/python-api"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "reference/cli/overview",
              "reference/cli/sessions",
              "reference/cli/issues",
              "reference/cli/doctor",
              "reference/cli/replay",
              "reference/cli/timeline",
              "reference/cli/search",
              "reference/cli/data-views",
              "reference/cli/export",
              "reference/cli/maintenance"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/apilens/slomo"
      }
