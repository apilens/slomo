            "pages": [
              "concepts/how-it-works",
              "concepts/sessions-and-events",
              "concepts/issues"
            ]
          },
          {
            "group": "Recording",
            "pages": [
              "recording/auto-tracing",
              "recording/manual-instrumentation",
              "recording/web-frameworks",
              "recording/workers-and-async",
              "recording/redaction"
            ]
          },
          {
            "group": "Investigating",
            "pages": [
              "investigating/issues-workflow",
              "investigating/replay",
              "investigating/search-and-timeline",
